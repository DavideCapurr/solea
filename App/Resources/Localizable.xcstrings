    "La pelle è arrossata: Solea blocca il sole diretto per oggi.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your skin is red, so Solea blocks direct sun exposure for today."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La piel está enrojecida: Solea bloquea el sol directo por hoy."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La peau est rougie : Solea bloque le soleil direct pour aujourd'hui."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Haut ist gerötet: Solea blockiert für heute die direkte Sonne."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A pele está avermelhada: o Solea bloqueia o sol direto por hoje."
          }
        }
      }
    },
    "La pelle è calda: Solea riduce automaticamente dose e obiettivo.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your skin feels warm, so Solea automatically reduces the dose and goal."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La piel está caliente: Solea reduce automáticamente la dosis y el objetivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La peau est chaude : Solea réduit automatiquement la dose et l'objectif."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Haut ist warm: Solea reduziert automatisch Dosis und Ziel."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A pele está quente: o Solea reduz automaticamente a dose e o objetivo."
          }
        }
      }
    },
    "La pelle tira: il recupero viene prima dell'abbronzatura.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your skin feels tight: recovery comes before tanning."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La piel tira: la recuperación es antes que el bronceado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La peau tire : la récupération passe avant le bronzage."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Haut spannt: Erholung geht vor Bräune."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A pele repuxa: a recuperação vem antes do bronzeado."
          }
        }
      }
    },
    "La pelle tira: meglio fermarsi, stare all'ombra e recuperare.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your skin feels tight: stop, move to the shade and let it recover."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La piel tira: mejor parar, ponerse a la sombra y recuperar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La peau tire : mieux vaut s'arrêter, se mettre à l'ombre et récupérer."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Haut spannt: besser aufhören, in den Schatten gehen und erholen."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A pele repuxa: melhor parar, ficar à sombra e recuperar."
          }
        }
      }
    },
    "La prossima volta riduci qualche minuto o aumenta SPF; stasera doposole.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Next time, shorten the session by a few minutes or use a higher SPF. Apply after-sun care tonight."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La próxima vez reduce unos minutos o aumenta el SPF; esta noche, aftersun."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La prochaine fois, réduisez quelques minutes ou augmentez le SPF ; ce soir, après-soleil."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nächstes Mal ein paar Minuten weniger oder höheren LSF; heute Abend After-Sun."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Da próxima vez reduz alguns minutos ou aumenta o FPS; esta noite, pós-solar."
          }
        }
      }
    },
