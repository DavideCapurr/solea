    "Le condizioni sono tra le più favorevoli per il tuo fototipo. Entra in Solea e avvia una sessione prudente.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Conditions are among the best for your skin type. Open Solea and start a cautious session."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las condiciones son de las más favorables para tu fototipo. Entra en Solea e inicia una sesión prudente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les conditions sont parmi les plus favorables pour votre phototype. Entrez dans Solea et lancez une séance prudente."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Bedingungen gehören zu den günstigsten für deinen Hauttyp. Öffne Solea und starte eine umsichtige Sitzung."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "As condições estão entre as mais favoráveis para o teu fototipo. Entra no Solea e inicia uma sessão prudente."
          }
        }
      }
    },
