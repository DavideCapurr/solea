    },
    "Il proxy cloud è pronto; il modello locale non è disponibile su questo dispositivo.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The cloud proxy is ready; the local model is not available on this device."
