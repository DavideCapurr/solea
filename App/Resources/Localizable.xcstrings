          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Autorisation d'écriture dans Santé refusée. Activez-la dans Santé > Profil > Apps > Solea."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schreibzugriff auf Health verweigert. Du kannst ihn in Health > Profil > Apps > Solea aktivieren."
