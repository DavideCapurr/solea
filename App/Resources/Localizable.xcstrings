    "Accedi a Game Center (Impostazioni > Game Center) per classifiche e obiettivi.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sign in to Game Center (Settings > Game Center) for leaderboards and achievements."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Inicia sesión en Game Center (Ajustes > Game Center) para clasificaciones y logros."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Connectez-vous à Game Center (Réglages > Game Center) pour les classements et les succès."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Melde dich bei Game Center an (Einstellungen > Game Center) für Bestenlisten und Erfolge."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Inicia sessão no Game Center (Definições > Game Center) para classificações e objetivos."
          }
        }
      }
    },
