    "Nessuna" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "None" } } } },
    "Come reagisce la tua pelle al sole prolungato senza protezione?" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "How does your skin react to prolonged sun without sunscreen?" } } } },
    "Mi scotto sempre, non mi abbronzo mai" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "I always burn, I never tan" } } } },
    "Mi scotto facilmente, mi abbronzo poco" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "I burn easily, I tan a little" } } } },
    "A volte mi scotto, poi mi abbronzo" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "I sometimes burn, then I tan" } } } },
    "Raramente mi scotto, mi abbronzo bene" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "I rarely burn, I tan well" } } } },
    "Non mi scotto quasi mai" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "I almost never burn" } } } },
    "Che grado di abbronzatura raggiungi?" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "How deep a tan do you get?" } } } },
    "Leggera" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Light" } } } },
    "Media" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Medium" } } } },
    "Intensa" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Deep" } } } },
    "La mia pelle è naturalmente scura" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "My skin is naturally dark" } } } },
    "Pelle molto chiara: si scotta sempre, non si abbronza." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Very fair skin: always burns, never tans." } } } },
    "Pelle chiara: si scotta facilmente, si abbronza poco." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Fair skin: burns easily, tans minimally." } } } },
    "Pelle intermedia: a volte si scotta, si abbronza gradualmente." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Medium skin: sometimes burns, tans gradually." } } } },
    "Pelle olivastra: si scotta raramente, si abbronza bene." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Olive skin: rarely burns, tans well." } } } },
    "Pelle scura: si scotta molto raramente, si abbronza intensamente." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Dark skin: very rarely burns, tans deeply." } } } },
    "Pelle molto scura: non si scotta quasi mai." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Very dark skin: almost never burns." } } } }
