          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Solea-Sitzung abgeschlossen: %@, durchschnittlicher UV %@, %@ der empfohlenen Schwelle. ☀️"
          }
        },
        "pt": {
          "stringUnit": {
