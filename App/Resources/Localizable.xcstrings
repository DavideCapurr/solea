    "Come reagisce la tua pelle al sole prolungato senza protezione?": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "How does your skin react to prolonged sun without sunscreen?"
          }
        }
      }
    },
    "Mi scotto sempre, non mi abbronzo mai": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I always burn, I never tan"
          }
        }
      }
    },
    "Mi scotto facilmente, mi abbronzo poco": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I burn easily, I tan a little"
          }
        }
      }
    },
    "A volte mi scotto, poi mi abbronzo": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I sometimes burn, then I tan"
          }
        }
      }
    },
    "Raramente mi scotto, mi abbronzo bene": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I rarely burn, I tan well"
          }
        }
      }
    },
    "Non mi scotto quasi mai": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I almost never burn"
          }
        }
      }
    },
    "Che grado di abbronzatura raggiungi?": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "How deep a tan do you get?"
          }
        }
      }
    },
