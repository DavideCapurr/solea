    "Aggiungi una foto periodica per seguire l'evoluzione del tuo tono pelle. Le foto restano sul tuo dispositivo.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add a periodic photo to track how your skin tone evolves. Photos stay on your device."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade una foto periódica para seguir la evolución de tu tono de piel. Las fotos permanecen en tu dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez une photo régulière pour suivre l'évolution de votre teint. Les photos restent sur votre appareil."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge regelmäßig ein Foto hinzu, um die Entwicklung deines Hauttons zu verfolgen. Die Fotos bleiben auf deinem Gerät."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Adiciona uma foto periódica para acompanhar a evolução do teu tom de pele. As fotos ficam no teu dispositivo."
          }
        }
      }
    },
