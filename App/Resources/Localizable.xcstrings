    "Hai completato il tempo previsto: valuta ombra, doposole o una pausa.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You've completed the planned time. Move into the shade, apply after-sun care, or take a break."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Has completado el tiempo previsto: considera sombra, aftersun o una pausa."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous avez terminé le temps prévu : pensez à l'ombre, l'après-soleil ou une pause."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du hast die geplante Zeit erreicht: Denk an Schatten, After-Sun oder eine Pause."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Concluíste o tempo previsto: considera sombra, pós-solar ou uma pausa."
          }
        }
      }
    },
