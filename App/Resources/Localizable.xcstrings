    "Profilo" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Profile" } } } },
    "Il diario delle sessioni arriva con la prossima milestone." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The session diary arrives in the next milestone." } } } },
    "Benvenuto in Solea" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Welcome to Solea" } } } },
    "Abbronzati al meglio, senza scottarti: tempi di esposizione su misura per la tua pelle e l'UV reale della tua zona." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Get your best tan without burning: exposure times tailored to your skin and the real UV in your area." } } } },
    "Solea fornisce stime informative, non consigli medici. In caso di dubbi sulla tua pelle consulta un dermatologo." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Solea provides informational estimates, not medical advice. If in doubt about your skin, consult a dermatologist." } } } },
    "Scopri il tuo fototipo" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Discover your skin type" } } } },
