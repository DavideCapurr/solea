    "Solea fornisce stime informative, non consigli medici.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Solea provides informational estimates, not medical advice."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solea ofrece estimaciones informativas, no consejos médicos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Solea fournit des estimations informatives, pas des conseils médicaux."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Solea liefert informative Schätzungen, keine medizinische Beratung."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A Solea fornece estimativas informativas, não conselhos médicos."
          }
        }
      }
    },
    "Solea fornisce stime informative, non consigli medici. In caso di dubbi sulla tua pelle consulta un dermatologo.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Solea provides informational estimates, not medical advice. If in doubt about your skin, consult a dermatologist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solea ofrece estimaciones informativas, no consejos médicos. Ante cualquier duda sobre tu piel, consulta a un dermatólogo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Solea fournit des estimations informatives, pas des conseils médicaux. En cas de doute sur votre peau, consultez un dermatologue."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Solea liefert informative Schätzungen, keine medizinische Beratung. Bei Zweifeln zu deiner Haut wende dich an eine Dermatologin oder einen Dermatologen."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A Solea fornece estimativas informativas, não conselhos médicos. Em caso de dúvidas sobre a tua pele, consulta um dermatologista."
          }
        }
      }
    },
