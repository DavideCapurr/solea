    "Permesso di posizione negato. Abilitalo in Impostazioni > Privacy > Localizzazione per vedere l'UV della tua zona.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Location permission denied. Enable it in Settings > Privacy > Location Services to see UV for your area."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Permiso de ubicación denegado. Actívalo en Ajustes > Privacidad > Localización para ver el UV de tu zona."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Autorisation de localisation refusée. Activez-la dans Réglages > Confidentialité > Service de localisation pour voir l'UV de votre région."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Standortberechtigung verweigert. Aktiviere sie in Einstellungen > Datenschutz > Ortungsdienste, um den UV-Wert deiner Region zu sehen."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Permissão de localização negada. Ativa-a em Definições > Privacidade > Localização para veres o UV da tua zona."
          }
        }
      }
    },
    "Permesso di scrittura su Salute negato. Puoi abilitarlo in Salute > Profilo > App > Solea.": {
      "localizations": {
