    "Stima breve per circa %lld IU di vitamina D, poi protezione o ombra.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A short estimate for about %lld IU of vitamin D, then protection or shade."
          }
        },
