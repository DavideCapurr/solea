    "Com'è la tua pelle dove non prende mai il sole?": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "What does your skin look like where it never gets sun?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Cómo es tu piel donde nunca le da el sol?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Comment est votre peau là où le soleil ne tape jamais ?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wie ist deine Haut an Stellen, die nie Sonne abbekommen?"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Como é a tua pele onde nunca apanha sol?"
          }
        }
      }
    },
    "Come reagisce la tua pelle al sole prolungato senza protezione?": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "How does your skin react to prolonged sun without sunscreen?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Cómo reacciona tu piel al sol prolongado sin protección?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Comment votre peau réagit-elle à une exposition prolongée sans protection ?"
          }
        },
        "de": {
