    "Nessun lato tracciato: dalla prossima sessione usa il selettore fronte/retro.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No side was tracked. Use the front/back selector during your next session."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ningún lado registrado: desde la próxima sesión usa el selector delante/detrás."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun côté suivi : dès la prochaine séance, utilisez le sélecteur avant/arrière."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Keine Seite erfasst: Nutze ab der nächsten Sitzung den Vorder-/Rückseiten-Wähler."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhum lado registado: a partir da próxima sessão usa o seletor frente/costas."
          }
        }
      }
    },
