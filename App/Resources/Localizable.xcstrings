    "Solea continuerà a mostrarti target, tempo, UV e limite prudente. Plus aggiunge tracciamento fronte/retro, promemoria personalizzati e Live Activity avanzata.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Solea will keep showing your target, time, UV and recommended limit. Plus adds front/back tracking, custom reminders and advanced Live Activity."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solea seguirá mostrándote objetivo, tiempo, UV y límite prudente. Plus añade seguimiento delante/detrás, recordatorios personalizados y Live Activity avanzada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Solea continuera de vous montrer objectif, temps, UV et limite prudente. Plus ajoute le suivi avant/arrière, des rappels personnalisés et une Live Activity avancée."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Solea zeigt dir weiterhin Ziel, Zeit, UV und empfohlenes Limit. Plus ergänzt Vorder-/Rückseiten-Tracking, personalisierte Erinnerungen und eine erweiterte Live Activity."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O Solea continuará a mostrar-te objetivo, tempo, UV e limite prudente. O Plus acrescenta registo frente/costas, lembretes personalizados e Live Activity avançada."
          }
        }
      }
    },
    "Solea ti richiama 30 minuti prima e quando inizia una finestra ideale, così puoi entrare nell'app e avviare una sessione prudente.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Solea reminds you 30 minutes before and when an ideal window starts, so you can open the app and begin a cautious session."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solea te avisa 30 minutos antes y cuando empieza una franja ideal, para que puedas entrar en la app e iniciar una sesión prudente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Solea vous rappelle 30 minutes avant et au début d'un créneau idéal, pour que vous puissiez ouvrir l'app et lancer une séance prudente."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Solea erinnert dich 30 Minuten vorher und zu Beginn eines idealen Zeitfensters, damit du die App öffnen und eine umsichtige Sitzung starten kannst."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O Solea avisa-te 30 minutos antes e quando começa uma janela ideal, para que possas abrir a app e iniciar uma sessão prudente."
          }
        }
      }
    },
    "Sono passate quasi due ore: rimetti la protezione solare.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "It's been almost two hours: reapply sunscreen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Han pasado casi dos horas: vuelve a ponerte protección solar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Près de deux heures se sont écoulées : remettez de la protection solaire."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fast zwei Stunden sind vergangen: trag erneut Sonnenschutz auf."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Passaram quase duas horas: volta a aplicar protetor solar."
          }
        }
      }
    },
