            "value": "Estimación breve de unas %lld UI de vitamina D, luego protección o sombra."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Estimation courte d'environ %lld UI de vitamine D, puis protection ou ombre."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
