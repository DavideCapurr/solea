    },
    "Stimato per il tuo fototipo %@ all'UV attuale; si aggiorna se l'UV cambia.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Estimated for skin type %@ at the current UV level; it updates when the UV level changes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estimado para tu fototipo %@ con el UV actual; se actualiza si el UV cambia."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Estimé pour votre phototype %@ à l'UV actuel ; mis à jour si l'UV change."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Geschätzt für deinen Hauttyp %@ beim aktuellen UV-Wert; wird aktualisiert, wenn sich der UV-Wert ändert."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Estimado para o teu fototipo %@ com o UV atual; atualiza-se se o UV mudar."
