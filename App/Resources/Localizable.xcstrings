    "Il sole disidrata: un sorso d'acqua aiuta pelle e abbronzatura.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The sun dehydrates you: a sip of water helps your skin and your tan."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El sol deshidrata: un sorbo de agua ayuda a tu piel y a tu bronceado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le soleil déshydrate : une gorgée d'eau aide votre peau et votre bronzage."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Sonne entzieht Wasser: ein Schluck hilft deiner Haut und deiner Bräune."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O sol desidrata: um gole de água ajuda a pele e o bronzeado."
          }
        }
      }
    },
