    "Permesso di posizione negato. Abilitalo in Impostazioni > Privacy > Localizzazione per vedere l'UV della tua zona." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Location permission denied. Enable it in Settings > Privacy > Location Services to see UV for your area." } } } },
