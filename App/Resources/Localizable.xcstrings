    "A volte mi scotto, poi mi abbronzo": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I sometimes burn, then I tan"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "A veces me quemo, luego me bronceo"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Parfois je brûle, puis je bronze"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Manchmal bekomme ich Sonnenbrand, dann werde ich braun"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Às vezes queimo, depois bronzeio"
          }
        }
      }
    },
