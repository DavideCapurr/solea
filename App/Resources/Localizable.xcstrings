    "Il fototipo determina i tempi di esposizione sicura: rifai il quiz se pensi che non ti rappresenti." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Your skin type determines safe exposure times: retake the quiz if it doesn't feel right." } } } },
    "Vuoi rifare il quiz del fototipo?" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Retake the skin type quiz?" } } } },
    "Annulla" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Cancel" } } } },
