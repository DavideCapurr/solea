    "Domani pausa dal sole diretto e idratazione: il rossore è un segnale da non ignorare.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Avoid direct sun tomorrow and stay hydrated: redness is a sign you shouldn't ignore."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mañana, pausa del sol directo e hidratación: el enrojecimiento es una señal que no hay que ignorar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Demain, pause du soleil direct et hydratation : la rougeur est un signal à ne pas ignorer."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Morgen Pause von direkter Sonne und Flüssigkeit: Rötung ist ein Signal, das du nicht ignorieren solltest."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Amanhã, pausa do sol direto e hidratação: a vermelhidão é um sinal a não ignorar."
          }
        }
      }
    },
