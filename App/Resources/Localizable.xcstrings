    "UV molto basso: puoi stare fuori, ma l'effetto su abbronzatura e vitamina D sarà minimo.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "UV is very low: you can stay outside, but the effect on tanning and vitamin D will be minimal."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "UV muy bajo: puedes estar fuera, pero el efecto sobre el bronceado y la vitamina D será mínimo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "UV très faible : vous pouvez rester dehors, mais l'effet sur le bronzage et la vitamine D sera minime."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sehr niedriger UV: Du kannst draußen bleiben, aber der Effekt auf Bräune und Vitamin D ist minimal."
