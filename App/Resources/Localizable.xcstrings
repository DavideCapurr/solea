    "A volte mi scotto, poi mi abbronzo": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I sometimes burn, then I tan"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "A veces me quemo, luego me bronceo"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Parfois je brûle, puis je bronze"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Manchmal bekomme ich Sonnenbrand, dann werde ich braun"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Às vezes queimo, depois bronzeio"
          }
        }
      }
    },
    "Abbronzati al meglio, senza scottarti: tempi di esposizione su misura per la tua pelle e l'UV reale della tua zona.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Get your best tan without burning: exposure times tailored to your skin and the real UV in your area."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Broncéate mejor, sin quemarte: tiempos de exposición a medida para tu piel y el UV real de tu zona."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bronzez au mieux, sans brûler : des temps d'exposition adaptés à votre peau et à l'UV réel de votre région."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bräune dich optimal, ohne dich zu verbrennen: Expositionszeiten, abgestimmt auf deine Haut und den realen UV-Wert deiner Region."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Bronzeie-se melhor, sem se queimar: tempos de exposição à medida da sua pele e do UV real da sua zona."
          }
        }
      }
    },
    "Aggiornamento UV non riuscito (uso l'ultimo valore noto): %@": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "UV update failed (using last known value): %@"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo actualizar el UV (se usa el último valor conocido): %@"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec de la mise à jour UV (dernière valeur connue utilisée) : %@"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "UV-Aktualisierung fehlgeschlagen (letzter bekannter Wert wird verwendet): %@"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Falha ao atualizar o UV (a usar o último valor conhecido): %@"
          }
        }
      }
    },
