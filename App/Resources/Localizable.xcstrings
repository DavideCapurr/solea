    "Nessuna finestra ideale nelle prossime 24 ore per il tuo fototipo." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "No ideal window in the next 24 hours for your skin type." } } } },
    "Le fasce in cui ti abbronzi bene con il minor rischio per il tuo fototipo." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The time slots where you tan well with the least risk for your skin type." } } } },
