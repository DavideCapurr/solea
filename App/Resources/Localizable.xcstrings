    "Dose pensata per abbronzarti gradualmente restando sotto il limite prudente del tuo fototipo.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A dose designed for gradual tanning while staying below the recommended limit for your skin type."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Dosis pensada para broncearte gradualmente manteniéndote por debajo del límite prudente de tu fototipo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dose pensée pour bronzer progressivement en restant sous la limite prudente de votre phototype."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dosis, um dich allmählich zu bräunen und dabei unter dem empfohlenen Limit deines Hauttyps zu bleiben."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Dose pensada para te bronzeares gradualmente, mantendo-te abaixo do limite prudente do teu fototipo."
          }
        }
      }
    },
    "Dose ridotta per giornate in cui vuoi minimizzare il rischio e non inseguire il tan.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A reduced dose for days when you want to minimize risk rather than chase a tan."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Dosis reducida para los días en que quieres minimizar el riesgo y no buscar el bronceado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dose réduite pour les journées où vous voulez minimiser le risque sans chercher le bronzage."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Reduzierte Dosis für Tage, an denen du das Risiko minimieren und nicht auf Bräune aus bist."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Dose reduzida para os dias em que queres minimizar o risco e não procurar o bronzeado."
          }
        }
      }
    },
