    "Quasi equilibrato: il prossimo cambio aiuta a pareggiare fronte e retro.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Almost balanced: turning over next will help even out front and back exposure."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Casi equilibrado: el próximo cambio ayuda a igualar delante y detrás."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Presque équilibré : le prochain changement aide à égaliser l'avant et l'arrière."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fast ausgeglichen: Der nächste Wechsel hilft, Vorder- und Rückseite anzugleichen."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Quase equilibrado: a próxima mudança ajuda a igualar a frente e as costas."
          }
        }
      }
    },
