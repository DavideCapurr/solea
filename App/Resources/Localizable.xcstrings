        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kein Gesicht erkannt: Richte die Kamera auf dein Gesicht, um den Ton zu vergleichen."
          }
        },
        "pt": {
          "stringUnit": {
