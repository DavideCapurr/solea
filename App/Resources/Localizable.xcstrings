    "Bella sessione! Sei rimasto sotto la soglia di sicurezza.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Great session! You stayed under the safety threshold."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¡Buena sesión! Te has mantenido por debajo del umbral de seguridad."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Belle séance ! Vous êtes resté sous le seuil de sécurité."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tolle Sitzung! Du bist unter der Sicherheitsschwelle geblieben."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Boa sessão! Manteve-se abaixo do limite de segurança."
          }
        }
      }
    },
