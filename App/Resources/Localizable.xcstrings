    "Avvia la tua prima sessione dalla schermata Oggi: la troverai qui.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start your first session from the Today screen: it will show up here."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Inicia tu primera sesión desde la pantalla Hoy: la encontrarás aquí."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lancez votre première séance depuis l'écran Aujourd'hui : vous la retrouverez ici."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Starte deine erste Sitzung über den Bildschirm „Heute“ – du findest sie dann hier."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Inicia a tua primeira sessão no ecrã Hoje: vais encontrá-la aqui."
          }
        }
      }
    },
