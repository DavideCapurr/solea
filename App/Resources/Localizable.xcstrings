    "Pelle arrossata: niente sole diretto oggi, idratazione e doposole.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your skin is red: avoid direct sun today, stay hydrated, and use after-sun care."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Piel enrojecida: nada de sol directo hoy, hidratación y aftersun."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Peau rougie : pas de soleil direct aujourd'hui, hydratation et après-soleil."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gerötete Haut: heute keine direkte Sonne, Flüssigkeit und After-Sun."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Pele avermelhada: nada de sol direto hoje, hidratação e pós-solar."
          }
        }
      }
    },
    "Pelle calda: piano ridotto, niente ricerca aggressiva del tan.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Warm skin: a reduced plan with no aggressive tanning."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Piel caliente: plan reducido, sin buscar el bronceado de forma agresiva."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Peau chaude : plan réduit, pas de recherche agressive du bronzage."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Warme Haut: reduzierter Plan, kein aggressives Streben nach Bräune."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Pele quente: plano reduzido, sem procurar o bronzeado de forma agressiva."
          }
        }
      }
    },
    "Pelle calda: piano ridotto, senza forzare l'abbronzatura.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your skin feels warm, so the plan is reduced to avoid pushing your tan."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Piel caliente: plan reducido, sin forzar el bronceado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Peau chaude : plan réduit, sans forcer le bronzage."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Warme Haut: reduzierter Plan, ohne die Bräune zu erzwingen."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Pele quente: plano reduzido, sem forçar o bronzeado."
          }
        }
      }
    },
    "Pelle chiara: si scotta facilmente, si abbronza poco.": {
