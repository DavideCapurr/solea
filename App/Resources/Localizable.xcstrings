    "Tanora continuerà a mostrarti target, tempo, UV e limite prudente. Plus aggiunge tracciamento fronte/retro, promemoria personalizzati e Live Activity avanzata." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tanora zeigt dir weiterhin Ziel, Zeit, UV und empfohlenes Limit. Plus ergänzt Vorder-/Rückseiten-Tracking, personalisierte Erinnerungen und eine erweiterte Live Activity."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tanora will keep showing your target, time, UV and recommended limit. Plus adds front/back tracking, custom reminders and advanced Live Activity."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tanora seguirá mostrándote objetivo, tiempo, UV y límite prudente. Plus añade seguimiento delante/detrás, recordatorios personalizados y Live Activity avanzada."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tanora continuera de vous montrer objectif, temps, UV et limite prudente. Plus ajoute le suivi avant/arrière, des rappels personnalisés et une Live Activity avancée."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Tanora continuará a mostrar-te objetivo, tempo, UV e limite prudente. O Plus acrescenta registo frente/costas, lembretes personalizados e Live Activity avançada."
          }
        }
      }
    },
    "Tanora fornisce stime informative, non consigli medici." : {
      "localizations" : {
