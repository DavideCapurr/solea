    "Sessione intensa ma ancora sotto soglia: utile per abbronzarti gradualmente, senza aggiungere altro sole oggi." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Intensive Sitzung, aber noch unter der Schwelle: gut, um dich allmählich zu bräunen, ohne heute mehr Sonne hinzuzufügen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "An intense session that stayed below the limit and supports a gradual tan. Avoid any more sun today."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sesión intensa pero aún bajo el umbral: útil para broncearte gradualmente, sin añadir más sol hoy."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Séance intense mais encore sous le seuil : utile pour bronzer progressivement, sans ajouter de soleil aujourd'hui."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sessão intensa mas ainda abaixo do limite: útil para te bronzeares gradualmente, sem adicionar mais sol hoje."
          }
        }
      }
    },
    "Sessione più breve dell'obiettivo: utile come esposizione leggera, ma il risultato sarà graduale." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sitzung kürzer als das Ziel: gut als leichte Exposition, aber das Ergebnis wird allmählich kommen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This session was shorter than your goal. It still counts as light exposure, but results will be gradual."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sesión más corta que el objetivo: útil como exposición ligera, pero el resultado será gradual."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Séance plus courte que l'objectif : utile comme exposition légère, mais le résultat sera progressif."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sessão mais curta do que o objetivo: útil como exposição ligeira, mas o resultado será gradual."
          }
        }
      }
    },
