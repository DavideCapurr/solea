    "In pausa: i promemoria ripartono quando riprendi.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Paused: reminders will resume when you continue."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "En pausa: los recordatorios se reanudan cuando continúes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "En pause : les rappels reprennent quand vous reprenez."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Pausiert: Die Erinnerungen starten neu, wenn du fortfährst."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Em pausa: os lembretes recomeçam quando retomares."
          }
        }
      }
    },
    "In pausa: l'obiettivo non avanza finché non riprendi l'esposizione.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Paused: progress toward your goal will resume when you continue the session."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "En pausa: el objetivo no avanza hasta que reanudes la exposición."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "En pause : l'objectif n'avance pas tant que vous ne reprenez pas l'exposition."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Pausiert: Das Ziel kommt nicht voran, bis du die Exposition fortsetzt."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Em pausa: o objetivo não avança até retomares a exposição."
          }
        }
      }
    },
    "Incrociamo fototipo e UV reale per darti una stima quotidiana semplice, personale e prudente.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We combine your skin type with live UV data to give you a simple, personalized, and cautious daily estimate."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
