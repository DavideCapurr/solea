    "Castano scuro" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Dark brown" } } } },
    "Neri" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Black" } } } },
    "Com'è la tua pelle dove non prende mai il sole?" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "What does your skin look like where it never gets sun?" } } } },
    "Molto chiara, lattea" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Very fair, milky" } } } },
    "Chiara" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Fair" } } } },
    "Chiara con sfumatura beige" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Fair with a beige tint" } } } },
