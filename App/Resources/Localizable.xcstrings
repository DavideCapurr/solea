    "Scura" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Dark" } } } },
    "Quante lentiggini hai sulle zone non esposte?" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "How many freckles do you have on unexposed areas?" } } } },
