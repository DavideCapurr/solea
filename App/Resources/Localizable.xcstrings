    "Hai già preso abbastanza UV oggi: ombra, acqua e doposole.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You have already had enough UV today: shade, water and after-sun care."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ya has tomado suficiente UV hoy: sombra, agua y aftersun."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous avez déjà pris assez d'UV aujourd'hui : ombre, eau et après-soleil."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du hast heute schon genug UV abbekommen: Schatten, Wasser und After-Sun."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Já apanhaste UV suficiente hoje: sombra, água e pós-solar."
          }
        }
      }
    },
    "Hai raggiunto la dose massima per la tua pelle: mettiti all'ombra.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You've reached your skin's maximum dose: get in the shade."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Has alcanzado la dosis máxima para tu piel: ponte a la sombra."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous avez atteint la dose maximale pour votre peau : mettez-vous à l'ombre."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du hast die Maximaldosis für deine Haut erreicht: geh in den Schatten."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Atingiste a dose máxima para a tua pele: vai para a sombra."
          }
        }
      }
    },
    "Hai raggiunto la soglia prudente: oggi basta sole diretto.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You've reached the recommended limit: avoid any more direct sun today."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Has alcanzado el umbral prudente: por hoy, basta de sol directo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous avez atteint le seuil prudent : pour aujourd'hui, plus de soleil direct."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du hast die empfohlene Schwelle erreicht: für heute keine direkte Sonne mehr."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Atingiste o limite prudente: por hoje, chega de sol direto."
          }
        }
      }
    },
    "Hai sfiorato la dose massima: domani concedi una pausa alla tua pelle e idratati bene.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You came close to the maximum dose: give your skin a break tomorrow and stay well hydrated."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Has rozado la dosis máxima: mañana dale un respiro a tu piel e hidrátate bien."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous avez frôlé la dose maximale : demain, accordez une pause à votre peau et hydratez-vous bien."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du hast die Maximaldosis fast erreicht: gönn deiner Haut morgen eine Pause und trink ausreichend."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Quase atingiste a dose máxima: amanhã dá uma pausa à tua pele e hidrata-te bem."
          }
        }
      }
    },
    "Ho riapplicato la crema": {
