            "state": "translated",
            "value": "Deep"
          }
        }
      }
    },
    "La mia pelle è naturalmente scura": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "My skin is naturally dark"
          }
        }
      }
    },
    "Pelle molto chiara: si scotta sempre, non si abbronza.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Very fair skin: always burns, never tans."
          }
        }
      }
    },
    "Pelle chiara: si scotta facilmente, si abbronza poco.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fair skin: burns easily, tans minimally."
          }
        }
      }
    },
    "Pelle intermedia: a volte si scotta, si abbronza gradualmente.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Medium skin: sometimes burns, tans gradually."
          }
        }
      }
    },
    "Pelle olivastra: si scotta raramente, si abbronza bene.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Olive skin: rarely burns, tans well."
          }
        }
      }
    },
    "Pelle scura: si scotta molto raramente, si abbronza intensamente.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Dark skin: very rarely burns, tans deeply."
          }
        }
      }
    },
    "Pelle molto scura: non si scotta quasi mai.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Very dark skin: almost never burns."
          }
        }
      }
    },
