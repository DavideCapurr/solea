    },
    "Nessuna fascia futura da programmare: riapri Oggi quando cambiano le previsioni UV.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No future window to schedule: reopen Today when the UV forecast changes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay ninguna franja futura que programar: vuelve a abrir Hoy cuando cambien las previsiones UV."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun créneau futur à programmer : rouvrez Aujourd'hui quand les prévisions UV changent."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Keine zukünftige Zeit zu planen: Öffne „Heute“ erneut, wenn sich die UV-Vorhersage ändert."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhuma faixa futura para programar: reabre Hoje quando as previsões UV mudarem."
          }
        }
      }
    },
