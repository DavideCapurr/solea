        }
      }
    },
    "Stimato per il tuo fototipo %@ in base all'equivalente UV della potenza scelta. È una stima: segui sempre le indicazioni del centro.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Estimated for skin type %@ using the UV equivalent of the selected intensity. This is only an estimate; always follow the salon's guidance."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estimado para tu fototipo %@ según el equivalente UV de la potencia elegida. Es una estimación: sigue siempre las indicaciones del centro."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Estimé pour votre phototype %@ selon l'équivalent UV de la puissance choisie. C'est une estimation : suivez toujours les consignes du centre."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Geschätzt für deinen Hauttyp %@ anhand des UV-Äquivalents der gewählten Leistung. Eine Schätzung: Beachte stets die Hinweise des Studios."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Estimado para o teu fototipo %@ com base no equivalente UV da potência escolhida. É uma estimativa: segue sempre as indicações do centro."
