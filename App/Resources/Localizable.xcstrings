    "Ho scoperto il mio fototipo con Solea: %@. Ora posso fare il mio check solare quotidiano. ☀️": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I discovered my skin type with Solea: %@. Now I can do my daily sun check. ☀️"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "He descubierto mi fototipo con Solea: %@. Ahora puedo hacer mi check solar diario. ☀️"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "J'ai découvert mon phototype avec Solea : %@. Je peux maintenant faire mon check solaire quotidien. ☀️"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ich habe meinen Hauttyp mit Solea entdeckt: %@. Jetzt kann ich meinen täglichen Sonnen-Check machen. ☀️"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Descobri o meu fototipo com o Solea: %@. Agora posso fazer o meu check solar diário. ☀️"
          }
        }
      }
    },
    "Il Coach richiede il modello on-device (iOS 26+) oppure la configurazione del proxy cloud.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Coach requires the on-device model (iOS 26+) or the cloud proxy to be configured."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El Coach requiere el modelo en el dispositivo (iOS 26+) o la configuración del proxy en la nube."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le Coach nécessite le modèle sur l'appareil (iOS 26+) ou la configuration du proxy cloud."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Coach benötigt das On-Device-Modell (iOS 26+) oder die Konfiguration des Cloud-Proxys."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O Coach requer o modelo no dispositivo (iOS 26+) ou a configuração do proxy na nuvem."
          }
        }
      }
    },
    "Il proxy cloud è configurato, ma serve connessione per usarlo.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The cloud proxy is configured, but you need a connection to use it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El proxy en la nube está configurado, pero se necesita conexión para usarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le proxy cloud est configuré, mais une connexion est nécessaire pour l'utiliser."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Cloud-Proxy ist konfiguriert, aber für die Nutzung ist eine Verbindung nötig."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O proxy na nuvem está configurado, mas é necessária ligação para o usar."
